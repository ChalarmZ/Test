local function addLine(text, color, indent)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(1, 0, 0, 22)
    l.Text = (indent and "   " or "") .. text
    l.TextColor3 = color or Color3.fromRGB(200, 200, 200)
    l.BackgroundTransparency = 1
    l.Font = Enum.Font.Gotham
    l.TextSize = 13
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.BorderSizePixel = 0
    l.Parent = scroll
end

runBtn.MouseButton1Click:Connect(function()
    -- ล้างของเก่า
    for _, c in next, scroll:GetChildren() do
        if c:IsA("TextLabel") then c:Destroy() end
    end

    statusLbl.Text = "⏳ กำลังสแกน..."
    task.wait(0.1)

    local count = 0

    -- เช็ค PlayerPens ก่อนว่ามีไหม
    local pens = workspace:FindFirstChild("PlayerPens")
    if not pens then
        addLine("❌ ไม่เจอ workspace.PlayerPens", Color3.fromRGB(255,80,80))
        statusLbl.Text = "❌ ไม่เจอ PlayerPens"
        return
    end

    for _, v in next, pens:GetChildren() do
        local owner = v:GetAttribute("Owner")
        if owner == LocalPlayer.Name then
            local petsFolder = v:FindFirstChild("Pets")
            if not petsFolder then continue end
            for _, v1 in next, petsFolder:GetChildren() do
                count += 1
                local petName = v1:GetAttribute("Name") or v1.Name:sub(1, 12)
                addLine("══ " .. petName .. " ══", Color3.fromRGB(100, 180, 255))

                local attrs = v1:GetAttributes()
                local found = false
                for k, val in next, attrs do
                    found = true
                    local color = Color3.fromRGB(180, 180, 180)
                    local kl = k:lower()
                    if kl:find("rarity") then color = Color3.fromRGB(220, 180, 80)
                    elseif kl:find("name") then color = Color3.fromRGB(255, 255, 255)
                    elseif kl:find("mutation") then color = Color3.fromRGB(255, 150, 50)
                    elseif kl:find("level") or kl:find("xp") then color = Color3.fromRGB(100, 220, 255)
                    end
                    addLine(k .. " = " .. tostring(val), color, true)
                end
                if not found then
                    addLine("(ไม่มี attributes เลย)", Color3.fromRGB(100, 100, 100), true)
                end
            end
        end
    end

    if count == 0 then
        addLine("❌ ไม่พบ pet ในสวนเลย", Color3.fromRGB(255, 80, 80))
        addLine("Owner ที่เจอ:", Color3.fromRGB(180,180,180))
        for _, v in next, pens:GetChildren() do
            addLine("  - " .. tostring(v:GetAttribute("Owner")), Color3.fromRGB(150,150,150))
        end
        statusLbl.Text = "❌ ไม่เจอ pet"
    else
        statusLbl.Text = "✅ พบ " .. count .. " pets"
    end
end)
